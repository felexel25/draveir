---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <span class="fbrand"><span class="sigil" aria-hidden="true">✦</span> Draveir</span>
    <span>En el lugar donde brillan las estrellas · {year}</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-3);
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }
  .footer-inner {
    max-width: var(--page);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .fbrand { color: var(--text); font-weight: 500; }
</style>
