---
import { getCollection } from 'astro:content';
import { coverGradient } from '../lib/covers';
import { slugify } from '../lib/slug';
import { isFresh } from '../lib/fresh';
import Emblem from './Emblem.astro';

interface Props {
  slug: string;
  title: string;
  synopsis: string;
  status: string | null;
  format?: string | null;
  categories: string[];
  searchText?: string;
  /** Historia oculta: se imprime escondida y solo la destapa el buscador. */
  hidden?: boolean;
}

const { slug, title, synopsis, status, format, categories, searchText, hidden } = Astro.props;
const gradient = coverGradient(categories);
const primaryCategory = categories[0];

// ¿Tiene algún capítulo publicado hace menos de 3 días? La card lo sabe sola:
// getCollection está memoizado en el build, así que preguntarlo por card es barato.
const now = new Date();
const isNew = (await getCollection('chapters')).some(
  (c) => c.data.novelSlug === slug && isFresh(c.data.publishedAt, now),
);
---

<li class="novel-card" data-search={searchText} data-format={format ?? undefined}
    data-hidden={hidden ? '' : undefined} style={hidden ? 'display:none' : undefined}>
  <a class="cover-link" href={`/novela/${slug}`} aria-hidden="true" tabindex="-1">
    <span class="plate" style={`background:${gradient}`}>
      <span class="corner sigil" aria-hidden="true">✦</span>
      <Emblem slug={slug} />
    </span>
  </a>
  <div class="body">
    {primaryCategory && <span class="eyebrow cat">{primaryCategory}</span>}
    <h3><a href={`/novela/${slug}`}>{title}</a></h3>
    <p class="synopsis">{synopsis}</p>
    <div class="meta">
      {isNew && <span class="new-badge">Nuevo</span>}
      {status && <a class="status" data-status={slugify(status)} href={`/estado/${slugify(status)}`}>{status}</a>}
      {format && <a class="format" href={`/formato/${slugify(format)}`}>{format}</a>}
      {categories.slice(0, 2).map((c) => (
        <a class="tag" href={`/categoria/${slugify(c)}`}>{c}</a>
      ))}
    </div>
  </div>
</li>

<style>
  .novel-card { display: flex; flex-direction: column; }
  .cover-link { display: block; margin-bottom: var(--space-3); }
  .cover-link .plate { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  @media (prefers-reduced-motion: no-preference) {
    .cover-link:hover .plate { transform: translateY(-5px); box-shadow: 0 26px 46px -20px rgba(0, 0, 0, 0.7); }
  }
  .cat { display: block; margin-bottom: var(--space-2); }
  .novel-card h3 { margin: 0 0 var(--space-2); }
  .novel-card h3 a { color: var(--text); }
  .novel-card h3 a:hover { color: var(--accent); }
  .synopsis {
    color: var(--text-muted);
    font-size: 0.98rem;
    margin: 0 0 var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .meta { margin-top: auto; }
  .meta .new-badge { margin-right: var(--space-2); }
  /* Píldora de latón: distingue el formato del estado (píldora neutra) y de las
     categorías, y enlaza a /formato/<slug>. */
  .format {
    display: inline-block;
    font-family: var(--font-sans); font-size: var(--step--1);
    padding: 0.15rem 0.6rem; border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--brass) 45%, var(--border));
    color: var(--brass);
    margin-right: var(--space-2);
  }
  a.format:hover { border-color: var(--brass); }
</style>
