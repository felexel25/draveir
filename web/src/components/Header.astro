---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="sigil" aria-hidden="true">✦</span>
      <span class="mark">Draveir</span>
    </a>

    <nav class="site-nav" id="site-nav" data-open="false" aria-label="Principal">
      <a href="/novelas">Novelas</a>
      <a href="/buscar">Buscar</a>
      <a href="/biblioteca">Biblioteca</a>
      <a href="/acerca" class="nav-mobile">Acerca</a>
    </nav>

    <div class="header-actions">
      <a href="/acerca" class="about-link">Acerca</a>
      <button id="theme-toggle" type="button" aria-label="Cambiar tema" title="Cambiar tema">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
        </svg>
      </button>
      <button id="nav-toggle" class="nav-toggle" type="button" aria-label="Abrir menú" aria-controls="site-nav" aria-expanded="false">
        <svg class="i-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
        <svg class="i-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    max-width: var(--page);
    margin-inline: auto;
    min-height: 62px;
    padding: 0 var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .brand { display: flex; align-items: baseline; gap: 0.55rem; color: var(--text); }
  .brand .sigil { font-size: 0.85rem; transform: translateY(-1px); }
  .brand .mark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .site-nav { display: flex; align-items: center; gap: 1.6rem; font-family: var(--font-sans); font-size: 0.92rem; }
  .site-nav a { color: var(--text-muted); font-weight: 500; }
  .site-nav a:hover { color: var(--text); }

  .header-actions { margin-left: auto; display: flex; align-items: center; gap: 0.6rem; }

  /* "Acerca" junto al botón de tema en escritorio; en el desplegable móvil va aparte */
  .about-link { font-family: var(--font-sans); font-size: 0.92rem; font-weight: 500; color: var(--text-muted); margin-right: 0.4rem; }
  .about-link:hover { color: var(--text); }
  .site-nav .nav-mobile { display: none; }

  #theme-toggle,
  .nav-toggle {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    background: var(--surface);
    border: 1px solid var(--line-bright);
    color: var(--text);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  #theme-toggle:hover,
  .nav-toggle:hover { border-color: var(--accent); }

  /* La hamburguesa solo aparece en móvil */
  .nav-toggle { display: none; }
  .nav-toggle .i-close { display: none; }
  .nav-toggle[aria-expanded='true'] .i-open { display: none; }
  .nav-toggle[aria-expanded='true'] .i-close { display: block; }

  @media (max-width: 600px) {
    .brand .mark { font-size: 1.15rem; letter-spacing: 0.14em; }
    .nav-toggle { display: grid; }
    .about-link { display: none; }
    .site-nav .nav-mobile { display: block; }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow);
      font-size: 1rem;
      display: none;
    }
    .site-nav[data-open='true'] { display: flex; }
    .site-nav a {
      padding: 0.9rem var(--space-3);
      border-top: 1px solid var(--border);
      color: var(--text);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    #theme-toggle, .nav-toggle, .site-nav a { transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease; }
  }
</style>

<script>
  import { nextTheme, THEME_KEY, type Theme } from '../lib/theme';

  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const current = (document.documentElement.dataset.theme as Theme) ?? 'dark';
    const next = nextTheme(current);
    document.documentElement.dataset.theme = next;
    localStorage.setItem(THEME_KEY, next);
  });

  const navBtn = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  const setOpen = (open: boolean) => {
    navBtn?.setAttribute('aria-expanded', String(open));
    navBtn?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    if (nav) nav.dataset.open = String(open);
  };
  navBtn?.addEventListener('click', () => {
    setOpen(navBtn.getAttribute('aria-expanded') !== 'true');
  });
  // Cerrar al pulsar un enlace o Escape
  nav?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
