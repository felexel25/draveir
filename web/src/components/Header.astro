---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="sigil" aria-hidden="true">✦</span>
      <span class="mark">Draveir</span>
    </a>
    <nav class="site-nav" aria-label="Principal">
      <a href="/novelas">Novelas</a>
      <a href="/buscar">Buscar</a>
      <a href="/biblioteca">Biblioteca</a>
    </nav>
    <button id="theme-toggle" type="button" aria-label="Cambiar tema" title="Cambiar tema">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
      </svg>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    max-width: var(--page);
    margin-inline: auto;
    min-height: 62px;
    padding: 0.5rem var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-3) var(--space-4);
    flex-wrap: wrap;
  }
  .brand { display: flex; align-items: baseline; gap: 0.55rem; color: var(--text); }
  .brand .sigil { font-size: 0.85rem; transform: translateY(-1px); }
  .brand .mark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .site-nav { display: flex; align-items: center; gap: 1.6rem; font-family: var(--font-sans); font-size: 0.92rem; }
  .site-nav a { color: var(--text-muted); font-weight: 500; }
  .site-nav a:hover { color: var(--text); }
  #theme-toggle {
    margin-left: auto; /* fija el botón al extremo final de la barra */
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    background: var(--surface);
    border: 1px solid var(--line-bright);
    color: var(--text);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  #theme-toggle:hover { border-color: var(--accent); }
  @media (max-width: 600px) {
    .brand .mark { font-size: 1.15rem; letter-spacing: 0.14em; }
    .site-nav { gap: 1rem; font-size: 0.85rem; }
  }
</style>

<script>
  import { nextTheme, THEME_KEY, type Theme } from '../lib/theme';

  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const current = (document.documentElement.dataset.theme as Theme) ?? 'dark';
    const next = nextTheme(current);
    document.documentElement.dataset.theme = next;
    localStorage.setItem(THEME_KEY, next);
  });
</script>
