---
import { EMBLEM_BODY, EMBLEM_STROKE, pickEmblem } from '../lib/emblem';
interface Props { slug: string; }
const { slug } = Astro.props;
// El build fija un emblema por slug; el script de abajo lo rota en cada carga.
// Sin JavaScript se ve este.
const name = pickEmblem(slug);
---
<svg class="emblem" viewBox="0 0 100 100" fill="none" stroke="currentColor"
     stroke-width={EMBLEM_STROKE[name]} stroke-linecap="round" stroke-linejoin="round"
     aria-hidden="true" data-emblem={slug}>
  <Fragment set:html={EMBLEM_BODY[name]} />
</svg>

<script>
  import { EMBLEMS, EMBLEM_BODY, EMBLEM_STROKE } from '../lib/emblem';

  // Un offset por carga: rota el set entero en cada recarga. Repartimos por
  // posición en la página (no por hash del slug) para que no se repita ningún
  // emblema entre las novelas visibles, cosa que un hash sí puede hacer.
  const offset = Math.floor(Math.random() * EMBLEMS.length);
  const plates = document.querySelectorAll<SVGElement>('svg[data-emblem]');
  plates.forEach((svg, i) => {
    const name = EMBLEMS[(i + offset) % EMBLEMS.length];
    svg.setAttribute('stroke-width', String(EMBLEM_STROKE[name]));
    svg.innerHTML = EMBLEM_BODY[name];
  });
</script>
