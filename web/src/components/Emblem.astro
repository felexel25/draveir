---
import type { Emblem } from '../lib/emblem';
interface Props { name: Emblem; }
const { name } = Astro.props;
---
<svg class="emblem" viewBox="0 0 100 100" fill="none" stroke="currentColor"
     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {name === 'sun' && (
    <Fragment>
      <circle cx="50" cy="50" r="15" />
      <line x1="73" y1="50" x2="82" y2="50" /><line x1="27" y1="50" x2="18" y2="50" />
      <line x1="50" y1="73" x2="50" y2="82" /><line x1="50" y1="27" x2="50" y2="18" />
      <line x1="66" y1="66" x2="72" y2="72" /><line x1="34" y1="34" x2="28" y2="28" />
      <line x1="66" y1="34" x2="72" y2="28" /><line x1="34" y1="66" x2="28" y2="72" />
    </Fragment>
  )}
  {name === 'moon' && (
    <Fragment>
      <path d="M60 20 A32 32 0 1 0 60 80 A25 25 0 1 1 60 20 Z" />
      <path d="M30 30 l1.5 3 3 1.5 -3 1.5 -1.5 3 -1.5 -3 -3 -1.5 3 -1.5 z" stroke-width="1.2" />
      <path d="M34 66 l1 2 2 1 -2 1 -1 2 -1 -2 -2 -1 2 -1 z" stroke-width="1.2" />
    </Fragment>
  )}
  {name === 'eclipse' && (
    <Fragment>
      <circle cx="50" cy="50" r="17" fill="rgba(0,0,0,0.35)" />
      <line x1="50" y1="26" x2="50" y2="20" /><line x1="50" y1="74" x2="50" y2="80" />
      <line x1="26" y1="50" x2="20" y2="50" /><line x1="74" y1="50" x2="80" y2="50" />
      <line x1="67" y1="33" x2="71" y2="29" /><line x1="33" y1="67" x2="29" y2="71" />
      <line x1="67" y1="67" x2="71" y2="71" /><line x1="33" y1="33" x2="29" y2="29" />
    </Fragment>
  )}
  {name === 'star' && (
    <Fragment>
      <path d="M50 15 L55 45 L85 50 L55 55 L50 85 L45 55 L15 50 L45 45 Z" />
      <line x1="50" y1="50" x2="68" y2="32" stroke-width="1.2" />
      <line x1="50" y1="50" x2="32" y2="32" stroke-width="1.2" />
      <line x1="50" y1="50" x2="68" y2="68" stroke-width="1.2" />
      <line x1="50" y1="50" x2="32" y2="68" stroke-width="1.2" />
    </Fragment>
  )}
  {name === 'planet' && (
    <Fragment>
      <circle cx="50" cy="50" r="16" />
      <ellipse cx="50" cy="50" rx="31" ry="11" transform="rotate(-22 50 50)" />
      <circle cx="79" cy="30" r="1.6" fill="currentColor" stroke="none" />
    </Fragment>
  )}
  {name === 'tower' && (
    <Fragment>
      <rect x="41" y="42" width="18" height="40" rx="1" />
      <rect x="47" y="54" width="6" height="9" />
      <path d="M41 42 v-4 h4 v-3 h5 v3 h5 v-3 h4 v3 h5 v4" />
      <path d="M57 16 L48 34 L54 34 L46 50" stroke-width="1.6" />
      <circle cx="30" cy="62" r="1.6" fill="currentColor" stroke="none" />
      <circle cx="70" cy="70" r="1.6" fill="currentColor" stroke="none" />
    </Fragment>
  )}
  {name === 'eye' && (
    <Fragment>
      <path d="M18 50 Q50 28 82 50 Q50 72 18 50 Z" />
      <circle cx="50" cy="50" r="9" />
      <circle cx="50" cy="50" r="3.2" fill="currentColor" stroke="none" />
      <line x1="50" y1="30" x2="50" y2="24" stroke-width="1.2" />
      <line x1="50" y1="70" x2="50" y2="76" stroke-width="1.2" />
    </Fragment>
  )}
</svg>
