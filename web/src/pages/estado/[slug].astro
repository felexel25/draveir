---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NovelCard from '../../components/NovelCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { slugify } from '../../lib/slug';
import { getReadableNovels } from '../../lib/novels';

export async function getStaticPaths() {
  const novels = await getReadableNovels();
  // Estados que existen de verdad en el catálogo; uno sin historias no genera página.
  const states = new Map<string, string>();
  for (const n of novels) {
    if (n.data.status) states.set(slugify(n.data.status), n.data.status);
  }
  return [...states].map(([slug, name]) => ({ params: { slug }, props: { name } }));
}

interface Props { name: string; }
const { name } = Astro.props;
const { slug } = Astro.params;

const novels = (await getReadableNovels())
  .filter((n) => n.data.status && slugify(n.data.status) === slug)
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'es'));
---

<BaseLayout title={`${name} — Draveir`}>
  <main class="container wide" id="contenido">
    <Breadcrumb items={[{ label: 'Historias', href: '/historias' }, { label: name }]} />
    <div class="page-head">
      <span class="eyebrow">Estado</span>
      <h1>{name}</h1>
    </div>
    <ul class="novel-grid">
      {novels.map((n) => (
        <NovelCard
          slug={n.data.slug}
          title={n.data.title}
          synopsis={n.data.synopsis}
          status={n.data.status}
          format={n.data.format}
          categories={n.data.categories}
        />
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  /* .wide y .novel-grid vienen de global.css. */
  .page-head { margin-bottom: var(--space-5); }
  .page-head h1 { margin: var(--space-1) 0 0; }
</style>
