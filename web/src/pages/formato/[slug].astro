---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NovelCard from '../../components/NovelCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { slugify } from '../../lib/slug';
import { getReadableNovels } from '../../lib/novels';

export async function getStaticPaths() {
  const novels = await getReadableNovels();
  // Formatos distintos que existen de verdad en el catálogo: un formato sin
  // historias no genera página (mismo criterio que las taxonomías).
  const formats = new Map<string, string>();
  for (const n of novels) {
    if (n.data.format) formats.set(slugify(n.data.format), n.data.format);
  }
  return [...formats].map(([slug, name]) => ({ params: { slug }, props: { name } }));
}

interface Props { name: string; }
const { name } = Astro.props;
const { slug } = Astro.params;

const novels = (await getReadableNovels())
  .filter((n) => n.data.format && slugify(n.data.format) === slug)
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'es'));
---

<BaseLayout title={`${name} — Draveir`}>
  <main class="container wide" id="contenido">
    <Breadcrumb items={[{ label: 'Historias', href: '/historias' }, { label: name }]} />
    <div class="page-head">
      <span class="eyebrow">Formato</span>
      <h1>{name}</h1>
    </div>
    <ul class="novel-grid">
      {novels.map((n) => (
        <NovelCard
          slug={n.data.slug}
          title={n.data.title}
          synopsis={n.data.synopsis}
          status={n.data.status}
          format={n.data.format}
          categories={n.data.categories}
        />
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  /* .wide y .novel-grid vienen de global.css. */
  .page-head { margin-bottom: var(--space-5); }
  .page-head h1 { margin: var(--space-1) 0 0; }
</style>
