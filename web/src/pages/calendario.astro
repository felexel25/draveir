---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Emblem from '../components/Emblem.astro';
import { coverGradient } from '../lib/covers';
import { releaseLabel, nextChapterLabel, romanNumeral, splitPhases } from '../lib/calendar';
import { isFresh } from '../lib/fresh';
import { getReadableNovels } from '../lib/novels';
import { readingOrder } from '../lib/saga';
import { slugify } from '../lib/slug';

// Todas las novelas menos las ocultas: el calendario muestra hasta las
// anunciadas sin capítulos, pero una historia oculta no se anuncia en ningún
// sitio — si apareciera aquí, dejaría de ser oculta.
const novels = (await getCollection('novels')).filter((n) => !n.data.hidden);
const chapters = await getCollection('chapters');
const locked = await getCollection('lockedChapters');
const phases = (await getCollection('phases'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => p.data);

// Fecha del capítulo 1 de cada novela: el hecho que manda sobre la promesa.
// El capítulo 1 puede venir de cualquiera de las dos colecciones — publicado
// (ya ocurrió) o programado (todavía una cuenta atrás) — así que miramos las
// dos y nos quedamos con el número 1 de cada novela, venga de donde venga.
const firstChapterAt = new Map<string, string>();
for (const c of chapters.filter((c) => c.data.number === 1)) {
  firstChapterAt.set(c.data.novelSlug, c.data.publishedAt);
}
for (const c of locked.filter((c) => c.data.number === 1)) {
  if (!firstChapterAt.has(c.data.novelSlug)) {
    firstChapterAt.set(c.data.novelSlug, c.data.unlocksAt);
  }
}
// Esta página es la única que ve TODAS las novelas, anunciadas incluidas: por eso
// usa getCollection en vez del helper. Pero quién enlaza y quién no lo decide el
// helper, no una copia de su regla: si diverge, el calendario enlazaría a fichas
// que no existen.
const readable = new Set((await getReadableNovels()).map((n) => n.data.slug));

// El próximo capítulo de cada novela: el programado más cercano. El capítulo 1
// NO cuenta — es el estreno, y ya lo anuncia la fecha de estreno (releaseLabel).
// Contarlo mostraba "Cap. 1 · <fecha>" redundante con el estreno (y absurdo en
// un relato de un solo capítulo). Una historia sin más capítulos no muestra
// esta línea.
const nextChapter = new Map<string, { number: number; at: string }>();
for (const c of locked) {
  if (c.data.number <= 1) continue;
  const prev = nextChapter.get(c.data.novelSlug);
  if (!prev || c.data.unlocksAt < prev.at) {
    nextChapter.set(c.data.novelSlug, { number: c.data.number, at: c.data.unlocksAt });
  }
}

// Historias con algún capítulo publicado hace menos de 3 días: llevan el badge
// NUEVO. Frescura medida contra la hora del build.
const now = new Date();
const freshNovels = new Set(
  chapters.filter((c) => isFresh(c.data.publishedAt, now)).map((c) => c.data.novelSlug),
);

// Las secciones de una cara. Se llama una vez por cara: cada una descarta sus
// fases vacías y numera las que quedan desde I.
function buildSections(caras: typeof phases) {
  return caras
    .map((p) => {
      const ofPhase = novels.filter((n) => n.data.phase === p.slug);
      const ordered = readingOrder(
        ofPhase.map((n) => ({ slug: n.data.slug, title: n.data.title, order: n.data.phaseOrder })),
      );
      const bySlug = new Map(ofPhase.map((n) => [n.data.slug, n.data]));
      return {
        phase: p,
        stories: ordered.map((o) => {
          const n = bySlug.get(o.slug)!;
          return {
            slug: n.slug,
            title: n.title,
            status: n.status,
            categories: n.categories,
            readable: readable.has(n.slug),
            isNew: freshNovels.has(n.slug),
            date: releaseLabel({
              firstChapterAt: firstChapterAt.get(n.slug) ?? null,
              releaseWindow: n.releaseWindow,
            }),
            next: (() => {
              const n2 = nextChapter.get(n.slug);
              const label = n2 ? nextChapterLabel(n2.at) : null;
              return label ? `Cap. ${n2!.number} · ${label}` : null;
            })(),
          };
        }),
      };
    })
    // Una fase sin historias no promete nada: no genera sección.
    .filter((s) => s.stories.length > 0)
    // El número de fase se asigna DESPUÉS de descartar las vacías: si la fase 2
    // se queda sin historias, no debe verse un salto de "Fase I" a "Fase III".
    .map((s, i) => ({ ...s, number: i + 1 }));
}

const { front, back } = splitPhases(phases);

// Las dos caras del calendario, misma forma y distinta promesa. El reverso sólo
// existe si alguna fase suya tiene historias: sin contenido, la página se
// comporta exactamente como antes de que existiera este feature — ni cara
// trasera, ni botón.
const faces = [
  {
    id: 'frente',
    reverse: false,
    eyebrow: 'Calendario',
    title: 'Lo que viene',
    lead: 'Las historias por fases, en orden de publicación.',
    sections: buildSections(front),
  },
  {
    id: 'reverso',
    reverse: true,
    eyebrow: 'El Reverso',
    title: 'Lo que no estaba',
    lead: 'Historias que salen cuando salen.',
    sections: buildSections(back),
  },
].filter((f) => !f.reverse || f.sections.length > 0);
---

<BaseLayout
  title="Calendario — Draveir"
  description="Todo lo que viene y todo lo que ya salió, fase por fase."
>
  <main class="container wide" id="contenido">
    {faces.length > 1 && (
      <button class="flip" id="flip" type="button" aria-controls="caras" aria-pressed="false">
        {/* El dorso de una carta con el sigilo de la casa: el objeto que se
            voltea es el propio botón, así la acción se anticipa sola. */}
        <span class="card" aria-hidden="true">
          <svg viewBox="0 0 34 48" fill="none" stroke="currentColor">
            <rect x="1.5" y="1.5" width="31" height="45" rx="3" stroke-width="1.2" />
            <rect x="5" y="5" width="24" height="38" rx="1.5" stroke-width="0.7" stroke-dasharray="2 3" />
            <g transform="translate(17 20) scale(0.72) translate(-12 -12)">
              <path fill="currentColor" stroke="none"
                    d="M12 4.4c.55 4.6 2.45 6.5 7.05 7.05C14.45 12 12.55 13.9 12 18.5c-.55-4.6-2.45-6.5-7.05-7.05C9.55 10.9 11.45 9 12 4.4Z" />
            </g>
            <path stroke-width="0.7" stroke-linecap="round" d="M11 33h12M13.5 37h7" />
          </svg>
        </span>
        <span class="flip-label" id="flip-label">voltear la carta</span>
      </button>
    )}

    <div id="caras">
      {faces.map((face, i) => (
        <div class="face" data-face={face.id} hidden={i > 0}>
          <div class="page-head">
            <span class="eyebrow">{face.eyebrow}</span>
            <h1>{face.title}</h1>
            <p class="lead">{face.lead}</p>
          </div>

          {face.sections.length === 0 && <p class="empty">Aún no hay fases publicadas.</p>}

          {face.sections.map((s) => (
            <section class="phase">
              <div class="phase-head">
                {/* El reverso no numera sus fases: numerarlas sería prometer un
                    orden y un ritmo, que es justo de lo que huye esta cara. */}
                {!face.reverse && <span class="phase-num">Fase {romanNumeral(s.number)}</span>}
                <h2>{s.phase.name}</h2>
                <p class="phase-count">
                  {s.stories.length} {s.stories.length === 1 ? 'historia' : 'historias'}
                </p>
                {s.phase.description && <p class="phase-desc">{s.phase.description}</p>}
              </div>
              <ol class={face.reverse ? 'timeline is-reverse' : 'timeline'}>
                {s.stories.map((story) => (
                  <li class={story.readable ? 'entry' : 'entry is-soon'}>
                    <span class="node" aria-hidden="true">✦</span>
                    <span class="plate mini" style={`background:${coverGradient(story.categories)}`} aria-hidden="true">
                      <Emblem slug={story.slug} />
                    </span>
                    <div class="entry-body">
                      <h3>
                        {story.readable
                          ? <a href={`/novela/${story.slug}`}>{story.title}</a>
                          : story.title}
                      </h3>
                      <p class="entry-meta">
                        {story.isNew && <span class="new-badge">Nuevo</span>}
                        {/* El reverso no lleva fechas — el estado sí: es un hecho
                            sobre la historia, no una promesa de cuándo sale. */}
                        {!face.reverse && story.date && <span class="when">{story.date}</span>}
                        {story.readable
                          ? story.status && <a class="status" data-status={slugify(story.status)} href={`/estado/${slugify(story.status)}`}>{story.status}</a>
                          : <span class="soon">Próximamente</span>}
                      </p>
                      {!face.reverse && story.next && <p class="entry-next">{story.next}</p>}
                    </div>
                  </li>
                ))}
              </ol>
            </section>
          ))}
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  /* Columna de lectura estrecha (misma que la ficha de novela), no el ancho de
     catálogo: el calendario se lee como una línea de tiempo, no como una rejilla. */
  .wide { max-width: 62rem; }
  .page-head { margin-bottom: var(--space-6); }
  .page-head h1 { margin: var(--space-1) 0 0; }
  .lead { color: var(--text-muted); font-size: 1.1rem; margin-top: var(--space-3); }
  .empty { color: var(--text-muted); font-family: var(--font-sans); }

  .phase { margin-bottom: var(--space-6); }
  .phase-head {
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-3);
    margin-bottom: var(--space-5);
  }
  /* El mismo interletrado de la marca en el header: es la voz de la casa. */
  .phase-num {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--brass);
    margin-bottom: var(--space-2);
  }
  .phase-head h2 { margin: 0; font-size: var(--step-2); }
  .phase-count {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--text-muted);
    margin: var(--space-1) 0 0;
  }
  .phase-desc { color: var(--text-muted); max-width: 60ch; margin: var(--space-3) 0 0; }

  /* El rail: un hilo de latón con nodos ✦, el sigilo de la marca. La línea
     corre por detrás; cada nodo se asienta sobre el fondo para taparla. */
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0 0 0 var(--space-5);
    display: grid;
    gap: var(--space-5);
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: 0.34rem;
    width: 1px;
    background: var(--border);
  }

  .entry { display: flex; gap: var(--space-4); align-items: center; position: relative; }
  .node {
    position: absolute;
    left: calc(var(--space-5) * -1);
    top: 50%;
    transform: translateY(-50%);
    width: 0.7rem;
    text-align: center;
    font-size: 0.7rem;
    line-height: 1;
    background: var(--bg);
    padding: var(--space-1) 0;
    color: var(--brass);
  }
  /* El hilo se apaga hacia el futuro: lo que aún no existe pesa menos. */
  .entry.is-soon .node { color: var(--line-bright); }

  .plate.mini { width: 56px; flex: none; aspect-ratio: 2 / 3; }

  /* La página-cartel del sitio: el único sitio donde los títulos van en caja alta. */
  .entry-body h3 {
    margin: 0 0 var(--space-2);
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .entry-body h3 a { color: var(--text); }
  .entry-body h3 a:hover { color: var(--accent); }

  .entry-meta {
    margin: 0; display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: baseline;
    font-family: var(--font-sans); font-size: var(--step--1);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .when { color: var(--text-muted); }
  .soon { color: var(--brass); }

  /* Mismo color que los capítulos bloqueados en la ficha de novela: que lo que
     aún no se puede leer signifique lo mismo en las dos páginas. */
  .entry-next {
    margin: var(--space-2) 0 0;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--warm);
  }

  /* La carta invertida: el mismo arcano leído por su sombra. Va con :global
     porque el SVG lo pinta <Emblem>, y los estilos de esta página están
     scopeados — sin él, el selector no alcanzaría al emblema (es la misma razón
     por la que `.plate .emblem` vive en global.css). */
  .timeline.is-reverse :global(.emblem) { transform: rotate(180deg); }

  /* El botón vive centrado sobre el título, no dentro de la cabecera: pertenece
     a la página entera, no a ninguna de las dos caras. */
  .flip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    margin: 0 auto var(--space-5);
    padding: var(--space-2);
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--brass);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .flip .card { display: block; opacity: 0.75; }
  .flip svg { width: 34px; height: 48px; display: block; }
  .flip-label { color: var(--text-muted); }
  .flip:hover .card { opacity: 1; }
  .flip:hover .flip-label { color: var(--brass); }

  .face[hidden] { display: none; }

  /* El giro en dos tiempos. No se montan las dos caras superpuestas en 3D: con
     páginas largas, preserve-3d pelea con la altura del documento y con el
     scroll. La cara visible gira hasta el canto, ahí se releva el contenido, y
     la nueva termina el giro desde el otro lado — que es además lo que hace una
     carta de verdad. Sólo hay una cara viva en cada instante. */
  @media (prefers-reduced-motion: no-preference) {
    .is-turning { animation: al-canto 0.3s ease-in forwards; }
    .is-landing { animation: del-canto 0.3s ease-out; }
    .flip .card { transition: opacity 0.2s ease, transform 0.2s ease; }
    .flip:hover .card { transform: rotate(-4deg) translateY(-2px); }

    /* La perspectiva va dentro del propio transform, no en una regla
       `perspective` aparte: esa sólo afecta a los HIJOS del elemento, y aquí el
       que gira es #caras. Sin esto el giro se ve plano, como un encogimiento. */
    @keyframes al-canto {
      from { transform: perspective(1600px) rotateY(0); }
      to { transform: perspective(1600px) rotateY(90deg); opacity: 0.25; }
    }
    @keyframes del-canto {
      from { transform: perspective(1600px) rotateY(-90deg); opacity: 0.25; }
      to { transform: perspective(1600px) rotateY(0); }
    }
  }

  @media (max-width: 600px) {
    .plate.mini { width: 44px; }
    .timeline { padding-left: var(--space-4); }
    .node { left: calc(var(--space-4) * -1); }
    .entry { gap: var(--space-3); }
  }
</style>

<script>
  const btn = document.getElementById('flip');
  const caras = document.getElementById('caras');

  // Sin fases de reverso no se pinta el botón: no hay nada que voltear.
  if (btn && caras) {
    const label = btn.querySelector('.flip-label')!;
    const faces = Array.from(caras.querySelectorAll<HTMLElement>('.face'));

    // `hidden` saca la cara del árbol de accesibilidad y del tabulador, así que
    // no hace falta marcarla `inert` por separado.
    const MEDIO_GIRO = 300; // debe coincidir con la duración de al-canto/del-canto

    function mostrar(reverso: boolean) {
      for (const f of faces) f.hidden = f.dataset.face !== (reverso ? 'reverso' : 'frente');
      btn!.setAttribute('aria-pressed', String(reverso));
      label.textContent = reverso ? 'volver' : 'voltear la carta';
    }

    const animar = matchMedia('(prefers-reduced-motion: no-preference)');
    let girando = false;
    // El objetivo del giro en curso: si llega un nuevo destino mientras se
    // está girando, la rama síncrona de abajo lo aplica ya, pero el
    // setTimeout del giro en marcha sigue vivo (no se cancela) y también va a
    // llamar a mostrar(). Si leyera su `reverso` cerrado por closure, pisaría
    // ese destino nuevo con el viejo. Leyendo esta variable compartida, ambas
    // llamadas terminan de acuerdo.
    let objetivo = false;

    function voltear(reverso: boolean) {
      objetivo = reverso;
      // Sin animación, o a mitad de un giro anterior: se releva y ya.
      if (!animar.matches || girando) {
        mostrar(reverso);
        return;
      }
      girando = true;
      caras!.classList.add('is-turning');
      setTimeout(() => {
        mostrar(objetivo);
        caras!.classList.replace('is-turning', 'is-landing');
        setTimeout(() => {
          caras!.classList.remove('is-landing');
          girando = false;
        }, MEDIO_GIRO);
      }, MEDIO_GIRO);
    }

    btn.addEventListener('click', () => {
      const reverso = btn.getAttribute('aria-pressed') !== 'true';
      // El hash hace el reverso compartible y devuelve el botón Atrás.
      history.pushState(null, '', reverso ? '#reverso' : location.pathname);
      voltear(reverso);
    });

    addEventListener('hashchange', () => voltear(location.hash === '#reverso'));

    // La carga inicial no gira: no ha habido volteo que animar.
    mostrar(location.hash === '#reverso');
  }
</script>
