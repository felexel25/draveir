---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NovelCard from '../components/NovelCard.astro';
import { coverGradient } from '../lib/covers';
import { novelHaystack } from '../lib/search';
import Emblem from '../components/Emblem.astro';
import { getReadableNovels } from '../lib/novels';
import { isFresh, relativeDayLabel } from '../lib/fresh';

const novels = (await getReadableNovels()).sort((a, b) =>
  a.data.title.localeCompare(b.data.title, 'es'),
);
const chapters = await getCollection('chapters');

// Recién salido: los capítulos publicados hace menos de 3 días, del más nuevo al
// menos. Si no hay ninguno, la sección no aparece (nada que anunciar).
const now = new Date();
const novelBySlug = new Map(novels.map((n) => [n.data.slug, n.data]));
const recent = chapters
  .filter((c) => isFresh(c.data.publishedAt, now) && novelBySlug.has(c.data.novelSlug))
  .sort((a, b) => b.data.publishedAt.localeCompare(a.data.publishedAt))
  .map((c) => {
    const n = novelBySlug.get(c.data.novelSlug)!;
    return {
      novelSlug: n.slug,
      novelTitle: n.title,
      gradient: coverGradient(n.categories),
      title: c.data.title,
      chapterSlug: c.data.chapterSlug,
      // Tiempo relativo ("hoy/ayer/hace N días") — un feed de novedades se lee
      // como algo vivo; la fecha exacta va en el title para quien la quiera.
      when: relativeDayLabel(c.data.publishedAt, now),
      date: new Date(c.data.publishedAt).toLocaleDateString('es', {
        day: 'numeric',
        month: 'short',
        timeZone: 'America/Panama',
      }),
    };
  });

const featured = novels.find((n) => n.data.featured) ?? novels[0];
const featuredGradient = featured ? coverGradient(featured.data.categories) : '';
const firstChapter = featured
  ? chapters
      .filter((c) => c.data.novelSlug === featured.data.slug)
      .sort((a, b) => a.data.number - b.data.number)[0]
  : undefined;
const readHref = firstChapter
  ? `/novela/${featured.data.slug}/${firstChapter.data.chapterSlug}`
  : featured
    ? `/novela/${featured.data.slug}`
    : '/historias';
---

<BaseLayout title="Draveir — Historias">
  <main class="wrap" id="contenido">
    {featured && (
      <section class="hero">
        <div class="hero-copy">
          <div class="kicker">
            <span class="line" aria-hidden="true"></span>
            <span class="eyebrow">Historia destacada · {featured.data.categories[0]}</span>
          </div>
          <h1>{featured.data.title}</h1>
          <p class="lead">{featured.data.synopsis}</p>
          <div class="cta-row">
            <a class="btn btn-primary" href={readHref}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              Comenzar a leer
            </a>
            <a class="btn btn-ghost" href="/historias">Ver todas las historias</a>
          </div>
        </div>
        <a class="hero-cover" href={`/novela/${featured.data.slug}`} aria-hidden="true" tabindex="-1">
          <span class="plate" style={`background:${featuredGradient}`}>
            <span class="corner sigil">✦</span>
            <Emblem slug={featured.data.slug} />
            <span class="plabel">{featured.data.status}</span>
          </span>
        </a>
      </section>
    )}

    {recent.length > 0 && (
      <section class="fresh-out">
        <div class="sec-head">
          <h2>Recién salido</h2>
          <span class="count">{recent.length} {recent.length === 1 ? 'capítulo' : 'capítulos'}</span>
        </div>
        <ul class="fresh-grid">
          {recent.map((c) => (
            <li>
              <a class="fresh-card" href={`/novela/${c.novelSlug}/${c.chapterSlug}`}>
                <span class="plate fresh-plate" style={`background:${c.gradient}`} aria-hidden="true">
                  <Emblem slug={c.novelSlug} />
                </span>
                <span class="fresh-copy">
                  <span class="fresh-novel">{c.novelTitle}</span>
                  <span class="fresh-title">{c.title}</span>
                  <span class="fresh-foot">
                    <span class="new-badge">Nuevo</span>
                    <span class="fresh-date" title={c.date}>{c.when}</span>
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="library">
      <div class="sec-head">
        <h2>Todas las historias</h2>
        <span class="count">{novels.length} {novels.length === 1 ? 'mundo' : 'mundos'}</span>
      </div>
      <ul class="novel-grid">
        {novels.map((n) => (
          <NovelCard
            slug={n.data.slug}
            title={n.data.title}
            synopsis={n.data.synopsis}
            status={n.data.status}
            format={n.data.format}
            categories={n.data.categories}
            searchText={novelHaystack(n.data)}
          />
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--page); margin-inline: auto; padding: 0 var(--space-3); }

  .hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-6) 0 var(--space-5);
  }
  .kicker { display: flex; align-items: center; gap: 0.75rem; margin-bottom: var(--space-4); }
  .kicker .line { height: 1px; width: 46px; background: var(--brass); opacity: 0.85; }
  .hero h1 { font-size: clamp(2rem, 7vw, 4.1rem); margin: 0 0 var(--space-4); }
  .hero .lead { font-size: 1.15rem; color: var(--text-muted); max-width: 46ch; margin: 0 0 var(--space-5); }
  .cta-row { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .hero-cover { display: block; justify-self: center; width: min(320px, 80%); }

  .library { padding: var(--space-3) 0 var(--space-6); }

  .fresh-out { padding: var(--space-3) 0 var(--space-4); }
  .fresh-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; gap: var(--space-4);
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  }
  .fresh-card {
    display: flex; gap: var(--space-4); align-items: center; height: 100%;
    padding: var(--space-3);
    border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--surface);
  }
  /* Carátula pequeña, sin la sombra grande del .plate normal. */
  .fresh-card .fresh-plate { width: 64px; flex: none; aspect-ratio: 2 / 3; box-shadow: none; }
  .fresh-copy { display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
  .fresh-novel {
    font-family: var(--font-sans); font-size: var(--step--1);
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted);
  }
  .fresh-title {
    font-family: var(--font-display); font-size: 1.2rem; line-height: 1.15; color: var(--text);
  }
  .fresh-foot { display: flex; align-items: center; gap: 0.7rem; margin-top: 0.15rem; }
  .fresh-date { font-family: var(--font-sans); font-size: var(--step--1); color: var(--text-muted); }
  /* Latón al pasar por encima: es lo recién salido, lo "caliente". */
  .fresh-card:hover { border-color: var(--brass); }
  .fresh-card:hover .fresh-title { color: var(--accent); }
  @media (prefers-reduced-motion: no-preference) {
    .fresh-card, .fresh-title { transition: border-color 0.15s ease, color 0.15s ease; }
  }

  @media (max-width: 860px) {
    .hero { grid-template-columns: 1fr; gap: var(--space-5); padding-top: var(--space-5); }
    .hero-cover { grid-row: 1; width: min(220px, 60%); justify-self: start; }
  }
  @media (max-width: 560px) {
    .cta-row { flex-wrap: nowrap; gap: 0.6rem; }
    .cta-row .btn { flex: 1; justify-content: center; padding-inline: 0.6rem; font-size: 0.9rem; }
    .cta-row .btn svg { display: none; }
  }
</style>
