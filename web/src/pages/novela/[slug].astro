---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Emblem from '../../components/Emblem.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import { coverGradient } from '../../lib/covers';
import { readingTime } from '../../lib/reading';
import { isFresh } from '../../lib/fresh';
import { formatSubtitle, formatMinutes } from '../../lib/format';
import { slugify } from '../../lib/slug';
import { readingOrder, positionIn } from '../../lib/saga';
import { getReadableNovels } from '../../lib/novels';

export async function getStaticPaths() {
  const novels = await getReadableNovels();
  return novels.map((n) => ({ params: { slug: n.data.slug } }));
}

const { slug } = Astro.params;
const novel = await getEntry('novels', slug);
if (!novel) return Astro.redirect('/novelas');

// Frescura de cada capítulo publicado, contra la hora del build.
const now = new Date();
const published = (await getCollection('chapters')).filter((c) => c.data.novelSlug === slug);
const locked = (await getCollection('lockedChapters')).filter((c) => c.data.novelSlug === slug);
const chapters = [
  ...published.map((c) => ({
    number: c.data.number,
    chapterSlug: c.data.chapterSlug,
    title: c.data.title,
    locked: false,
    minutes: readingTime(c.body),
    unlocksAt: '',
    isNew: isFresh(c.data.publishedAt, now),
  })),
  ...locked.map((c) => ({
    number: c.data.number,
    chapterSlug: c.data.chapterSlug,
    title: c.data.title,
    locked: true,
    minutes: 0,
    unlocksAt: c.data.unlocksAt,
    isNew: false,
  })),
].sort((a, b) => a.number - b.number);

// Solo los capítulos publicados: el texto de los bloqueados no está en el repo,
// así que se anuncia lo que hoy se puede leer, no un total imaginario.
const totalMinutes = published.length ? readingTime(published.map((c) => c.body).join(' ')) : 0;
const subtitle = formatSubtitle(novel.data.format);

const dateFmt = (iso: string) =>
  new Date(iso).toLocaleDateString('es', {
    day: 'numeric',
    month: 'short',
    timeZone: 'America/Panama',
  });

const gradient = coverGradient(novel.data.categories);

const saga = novel.data.saga ? await getEntry('sagas', novel.data.saga) : undefined;
const sagaPosition = saga
  ? positionIn(
      novel.data.slug,
      readingOrder(
        (await getReadableNovels())
          .filter((n) => n.data.saga === novel.data.saga)
          .map((n) => ({ slug: n.data.slug, title: n.data.title, order: n.data.sagaOrder })),
      ),
    )
  : null;
---

<BaseLayout title={`${novel.data.title} — Draveir`} description={novel.data.synopsis} ogType="book">
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Book',
    name: novel.data.title,
    author: { '@type': 'Person', name: 'Draveir' },
    description: novel.data.synopsis,
    inLanguage: 'es',
    genre: novel.data.categories,
  })} />
  <main class="detail" id="contenido">
    <Breadcrumb items={[{ label: 'Novelas', href: '/novelas' }, { label: novel.data.title }]} />
    <div class="novel-hero">
      <span class="plate" style={`background:${gradient}`} aria-hidden="true">
        <span class="corner sigil">✦</span>
        <Emblem slug={novel.data.slug} />
      </span>
      <div>
        {novel.data.categories[0] && <span class="eyebrow">{novel.data.categories[0]}</span>}
        <h1>{novel.data.title}</h1>
        <p class="synopsis">{novel.data.synopsis}</p>
        {(novel.data.format || totalMinutes > 0) && (
          <div class="format-block">
            {novel.data.format && (
              <span class="format">
                {novel.data.format}{subtitle && <span class="format-alt"> · {subtitle}</span>}
              </span>
            )}
            {totalMinutes > 0 && <span class="format-time">≈ {formatMinutes(totalMinutes)} de lectura</span>}
          </div>
        )}
        <div class="meta">
          {saga && (
            <a class="saga-line" href={`/saga/${saga.data.slug}`}>
              {sagaPosition && <span class="saga-pos">{sagaPosition}</span>}
              Saga {saga.data.name}
            </a>
          )}
          {novel.data.status && <span class="status">{novel.data.status}</span>}
          {novel.data.categories.map((c) => (
            <a class="tag" href={`/categoria/${slugify(c)}`}>{c}</a>
          ))}
        </div>
        <div class="detail-actions">
          <a class="btn btn-primary" id="continue-btn" href="#" hidden>Continuar leyendo</a>
          <FavoriteButton slug={novel.data.slug} />
        </div>
      </div>
    </div>

    <div class="sec-head"><h2>Capítulos</h2><span class="count">{chapters.length}</span></div>
    <ol class="chapter-list">
      {chapters.map((c) => (
        <li>
          <a href={`/novela/${slug}/${c.chapterSlug}`} class={c.locked ? 'locked' : ''} data-unlocks={c.locked ? c.unlocksAt : undefined}>
            <span>{c.locked && <span class="lock" aria-hidden="true">✦</span>}{c.title}{c.isNew && <span class="new-badge">Nuevo</span>}</span>
            <span class="ch-time">{c.locked ? `Se abre el ${dateFmt(c.unlocksAt)}` : `~${c.minutes} min`}</span>
          </a>
        </li>
      ))}
    </ol>
  </main>

  <script is:inline>
    // El build hornea el estado bloqueado; si la fecha ya pasó antes del próximo
    // rebuild (cada 6h), destrabamos la fila en vivo. El capítulo ya se abre solo
    // vía la Function, esto solo alinea la lista.
    for (const a of document.querySelectorAll('.chapter-list a.locked')) {
      const at = Date.parse(a.getAttribute('data-unlocks') || '');
      if (!Number.isNaN(at) && Date.now() >= at) {
        a.classList.remove('locked');
        a.querySelector('.lock')?.remove();
        // Recién abierto: es nuevo. Mismo badge que hornea el build; el próximo
        // rebuild lo sustituye por la versión estática con su tiempo de lectura.
        const title = a.querySelector('span');
        if (title && !title.querySelector('.new-badge')) {
          const badge = document.createElement('span');
          badge.className = 'new-badge';
          badge.textContent = 'Nuevo';
          title.appendChild(badge);
        }
        const t = a.querySelector('.ch-time');
        if (t) t.textContent = 'Disponible';
      }
    }
  </script>

  <script is:inline set:html={`window.__novelSlug=${JSON.stringify(novel.data.slug)};`}></script>
  <script>
    import { parseState, READER_KEY } from '../../lib/reader';
    const slug = (window as any).__novelSlug as string;
    const s = parseState(localStorage.getItem(READER_KEY));
    const ch = s.continueReading[slug];
    const btn = document.getElementById('continue-btn') as HTMLAnchorElement | null;
    if (btn && ch) {
      btn.href = `/novela/${slug}/${ch}`;
      btn.hidden = false;
    }
  </script>
</BaseLayout>

<style>
  .detail { max-width: 62rem; margin-inline: auto; padding: var(--space-5) var(--space-3); }
  .detail h1 { margin: var(--space-2) 0 var(--space-3); }
  .synopsis { color: var(--text-muted); font-size: 1.1rem; max-width: 52ch; }
  .detail-actions { display: flex; gap: 0.75rem; margin-top: var(--space-4); flex-wrap: wrap; align-items: center; }
  .chapter-list a.locked { color: var(--text-muted); }
  .chapter-list a.locked:hover { color: var(--text); }
  .chapter-list a.locked .ch-time { color: var(--warm); }
  .chapter-list .lock { color: var(--brass); margin-right: 0.45rem; font-size: 0.8em; }
  .saga-line { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--brass); text-decoration: none; }
  .saga-line:hover { text-decoration: underline; }
  .saga-pos { color: var(--text-muted); font-size: 0.85em; }
  .format-block { margin-top: var(--space-2); }
  .format, .format-time { display: block; font-family: var(--font-sans); font-size: var(--step--1); color: var(--text-muted); }
  .format-alt { font-style: italic; }
</style>
