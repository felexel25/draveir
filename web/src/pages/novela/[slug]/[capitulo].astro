---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChapterNav from '../../../components/ChapterNav.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Countdown from '../../../components/Countdown.astro';
import SagaFooter from '../../../components/SagaFooter.astro';
import { readingTime } from '../../../lib/reading';

type Props =
  | { kind: 'published'; entry: CollectionEntry<'chapters'> }
  | { kind: 'locked'; meta: CollectionEntry<'lockedChapters'>['data'] };

export async function getStaticPaths() {
  const published = await getCollection('chapters');
  const locked = await getCollection('lockedChapters');
  return [
    ...published.map((entry) => ({
      params: { slug: entry.data.novelSlug, capitulo: entry.data.chapterSlug },
      props: { kind: 'published', entry } as Props,
    })),
    ...locked.map((c) => ({
      params: { slug: c.data.novelSlug, capitulo: c.data.chapterSlug },
      props: { kind: 'locked', meta: c.data } as Props,
    })),
  ];
}

const props = Astro.props as Props;
const { slug } = Astro.params;
const novel = await getEntry('novels', slug);
const novelTitle = novel?.data.title ?? 'Novela';

const pub = (await getCollection('chapters')).filter((c) => c.data.novelSlug === slug);
const lok = (await getCollection('lockedChapters')).filter((c) => c.data.novelSlug === slug);
const items = [...pub, ...lok]
  .map((c) => ({ number: c.data.number, chapterSlug: c.data.chapterSlug, title: c.data.title }))
  .sort((a, b) => a.number - b.number)
  .map(({ chapterSlug, title }) => ({ chapterSlug, title }));

const title = props.kind === 'published' ? props.entry.data.title : props.meta.title;
const chapterSlug =
  props.kind === 'published' ? props.entry.data.chapterSlug : props.meta.chapterSlug;
const rendered = props.kind === 'published' ? await props.entry.render() : null;
const minutes = props.kind === 'published' ? readingTime(props.entry.body) : 0;

// El último capítulo PUBLICADO, aunque exista uno bloqueado por encima: ese es
// justo el caso "alcanzaste al autor", y también merece el bloque.
const lastPublished = Math.max(0, ...pub.map((c) => c.data.number));
const isLastPublished =
  props.kind === 'published' && props.entry.data.number === lastPublished;
---

<BaseLayout title={`${title} — Draveir`}>
  {props.kind === 'published' && <div class="reading-progress" id="reading-progress"></div>}
  <main class="container reading" id="contenido">
    <Breadcrumb items={[
      { label: 'Historias', href: '/historias' },
      { label: novelTitle, href: `/novela/${slug}` },
      { label: title },
    ]} />
    <div class="reading-top">
      <ChapterNav novelSlug={slug} current={chapterSlug} items={items} />
    </div>
    <h1>{title}</h1>

    {props.kind === 'published' && rendered ? (
      <Fragment>
        <p class="reading-meta">~{minutes} min de lectura</p>
        <article><rendered.Content /></article>
      </Fragment>
    ) : (
      props.kind === 'locked' && (
        <Countdown novelSlug={slug} chapterSlug={chapterSlug} unlocksAt={props.meta.unlocksAt} />
      )
    )}

    {isLastPublished && <SagaFooter novelSlug={slug} />}

    <div class="chapter-foot">
      <ChapterNav novelSlug={slug} current={chapterSlug} items={items} />
    </div>
  </main>

  {props.kind === 'published' && (
    <script is:inline set:html={`window.__chapter=${JSON.stringify({
      novelSlug: slug,
      chapterSlug: chapterSlug,
      title: `${novelTitle} · ${title}`,
    })};`}></script>
  )}
  {/* ponytail: corta clic derecho y copia sobre el texto del capítulo. Casual, no DRM. */}
  {props.kind === 'published' && (
    <script is:inline>
      {`document.querySelectorAll('.reading article').forEach((a) => {
        a.addEventListener('contextmenu', (e) => e.preventDefault());
        a.addEventListener('copy', (e) => e.preventDefault());
      });`}
    </script>
  )}
  {/* A NIVEL SUPERIOR, no dentro de un condicional: si va anidado en
     {cond && <Fragment>}, Astro no lo empaqueta y el progreso nunca se guarda.
     Se auto-desactiva en capítulos bloqueados (ahí no existe window.__chapter). */}
  <script>
    import { parseState, recordRead, setPosition, getPosition, READER_KEY } from '../../../lib/reader';

    const c = (window as any).__chapter as
      | { novelSlug: string; chapterSlug: string; title: string }
      | undefined;
    if (c) {
      const key = `${c.novelSlug}/${c.chapterSlug}`;

      // Abrir el capítulo ya cuenta como leído y como "seguir leyendo".
      const opened = recordRead(parseState(localStorage.getItem(READER_KEY)), { ...c, at: Date.now() });
      localStorage.setItem(READER_KEY, JSON.stringify(opened));

      const bar = document.getElementById('reading-progress');
      const scrollMax = () => Math.max(1, document.documentElement.scrollHeight - window.innerHeight);

      // Volver justo donde se quedó (si hay posición guardada).
      const saved = getPosition(opened, key);
      if (saved > 0) {
        requestAnimationFrame(() => window.scrollTo(0, saved * scrollMax()));
      }

      const paintBar = () => {
        const frac = Math.min(1, Math.max(0, window.scrollY / scrollMax()));
        if (bar) bar.style.width = frac * 100 + '%';
        return frac;
      };

      // Guardar la posición sin castigar el scroll: un respiro tras parar.
      let t = 0;
      document.addEventListener(
        'scroll',
        () => {
          const frac = paintBar();
          clearTimeout(t);
          t = window.setTimeout(() => {
            const next = setPosition(parseState(localStorage.getItem(READER_KEY)), key, frac);
            localStorage.setItem(READER_KEY, JSON.stringify(next));
          }, 400);
        },
        { passive: true },
      );
      window.addEventListener('resize', paintBar);
      paintBar();
    }
  </script>
</BaseLayout>
