---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  return chapters.map((c) => ({
    params: { slug: c.data.novelSlug, capitulo: c.data.chapterSlug },
    props: { entry: c },
  }));
}

interface Props {
  entry: CollectionEntry<'chapters'>;
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await entry.render();

const siblings = (await getCollection('chapters'))
  .filter((c) => c.data.novelSlug === slug)
  .sort((a, b) => a.data.number - b.data.number);
const idx = siblings.findIndex((c) => c.id === entry.id);
const prev = siblings[idx - 1];
const next = siblings[idx + 1];
---

<BaseLayout title={`${entry.data.title} — Draveir`}>
  <main class="container reading">
    <a href={`/novela/${slug}`}>← Índice</a>
    <h1>{entry.data.title}</h1>
    <article><Content /></article>
    <nav class="chapter-nav">
      {prev && <a href={`/novela/${slug}/${prev.data.chapterSlug}`}>← Anterior</a>}
      {next && <a href={`/novela/${slug}/${next.data.chapterSlug}`}>Siguiente →</a>}
    </nav>
  </main>
</BaseLayout>
