---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NovelCard from '../../components/NovelCard.astro';
import { getReadableNovels } from '../../lib/novels';

const novels = (await getReadableNovels()).sort((a, b) =>
  a.data.title.localeCompare(b.data.title, 'es'),
);
---

<BaseLayout title="Novelas — Draveir">
  <main class="container wide" id="contenido">
    <h1>Novelas</h1>
    <ul class="novel-grid">
      {novels.map((n) => (
        <NovelCard
          slug={n.data.slug}
          title={n.data.title}
          synopsis={n.data.synopsis}
          status={n.data.status}
          format={n.data.format}
          categories={n.data.categories}
        />
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  /* .wide y .novel-grid los pone global.css: mismo ancho y misma rejilla que el resto. */
</style>
