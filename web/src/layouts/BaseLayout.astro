---
import '@fontsource-variable/fraunces';
import '@fontsource/literata/400.css';
import '@fontsource/literata/600.css';
import '@fontsource/literata/400-italic.css';
import '@fontsource-variable/inter';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article' | 'book';
}

const {
  title,
  description = 'Novelas de fantasía, ciencia ficción, terror cósmico y misterio, por Draveir.',
  noindex = false,
  ogType = 'website',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Draveir" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta property="og:site_name" content="Draveir" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary" />
    <slot name="head" />
    <script is:inline>
      // Anti-FOUC: fija el tema antes del primer pintado.
      (function () {
        try {
          var stored = localStorage.getItem('draveir-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored === 'dark' || stored === 'light' ? stored : (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <Header />
    <slot />
    <Footer />
    <button id="to-top" class="to-top" type="button" aria-label="Volver arriba" hidden>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5" /><path d="M5 12l7-7 7 7" />
      </svg>
    </button>
    <script is:inline>
      // Aparece al bajar; vuelve arriba de un toque. Autónomo, sin imports.
      (function () {
        var btn = document.getElementById('to-top');
        if (!btn) return;
        var toggle = function () { btn.hidden = window.scrollY < 600; };
        document.addEventListener('scroll', toggle, { passive: true });
        toggle();
        btn.addEventListener('click', function () {
          var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
        });
      })();
    </script>
  </body>
</html>

<style>
  .to-top {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    background: var(--surface);
    color: var(--text-muted);
    border: 1px solid var(--line-bright);
    border-radius: 999px;
    box-shadow: var(--shadow);
    cursor: pointer;
    z-index: 25;
  }
  .to-top:hover { color: var(--brass); border-color: var(--brass); }
  @media (prefers-reduced-motion: no-preference) {
    .to-top { transition: color 0.15s ease, border-color 0.15s ease; }
  }
</style>
